NODE_ENV=development

# Database — file-based SQLite via libSQL (just a file, no DB server).
# Local dev: file:./data/app.db   |   Hosted (Turso): libsql://<db>.turso.io + DATABASE_AUTH_TOKEN
DATABASE_URL=file:./data/app.db
DATABASE_AUTH_TOKEN=

# Auth (custom JWT) — generate a long random string for production
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# App
NEXT_PUBLIC_BASE_URL=http://localhost:4000
DEFAULT_LOCALE=en
DEFAULT_CURRENCY=USD

# Storage driver: local | s3
STORAGE_DRIVER=local

# Stripe (test mode) — optional. When unset, card checkout is hidden and only COD is offered.
# STRIPE_WEBHOOK_SECRET comes from the Stripe dashboard webhook endpoint (or `stripe listen`).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
